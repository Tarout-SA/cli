{
	"name": "@tarout/cli",
	"version": "0.19.0",
	"description": "Tarout CLI — the Saudi cloud platform for coding agents",
	"type": "module",
	"bin": {
		"tarout": "./bin/tarout",
		"tarout-mcp": "./bin/tarout-mcp"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"bin",
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts src/mcp/stdio.ts --format esm --dts --clean",
		"dev": "tsup src/index.ts src/mcp/stdio.ts --format esm --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"test": "vitest run && bun test",
		"test:vitest": "vitest run",
		"test:bun": "bun test",
		"test:watch": "vitest",
		"start": "node dist/index.js",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@trpc/client": "^10.45.2",
		"@trpc/server": "^10.45.2",
		"chalk": "^5.3.0",
		"cli-table3": "^0.6.5",
		"commander": "^12.1.0",
		"conf": "^13.0.1",
		"express": "^4.21.0",
		"inquirer": "^12.0.0",
		"open": "^10.1.0",
		"ora": "^8.1.1",
		"superjson": "^2.2.2",
		"ws": "^8.16.0"
	},
	"devDependencies": {
		"@types/express": "^4.17.21",
		"@types/node": "^22.0.0",
		"@types/ws": "^8.5.10",
		"tsup": "^8.3.0",
		"typescript": "^5.6.0",
		"vitest": "^1.6.1"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Tarout-SA/cli.git"
	},
	"bugs": {
		"url": "https://github.com/Tarout-SA/cli/issues"
	},
	"homepage": "https://tarout.sa",
	"keywords": [
		"tarout",
		"paas",
		"cloud",
		"deployment",
		"cli"
	],
	"author": "Tarout",
	"license": "MIT"
}
